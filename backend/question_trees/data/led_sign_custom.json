{
    "job_type": "led_sign_custom",
    "version": "1.0",
    "display_name": "Custom LED / Illuminated Sign",
    "category": "signage",
    "required_fields": [
        "sign_type",
        "dimensions",
        "letter_height",
        "material"
    ],
    "questions": [
        {
            "id": "sign_type",
            "text": "What type of illuminated sign?",
            "type": "choice",
            "options": [
                "Channel letters (individual 3D letters)",
                "Cabinet / box sign (illuminated panel)",
                "Halo-lit / reverse-lit letters",
                "Light box (backlit panel)",
                "Custom LED artwork / sculpture"
            ],
            "required": true,
            "hint": "Channel letters are the most common commercial illuminated sign. Cabinet signs are simpler fabrication.",
            "depends_on": null,
            "branches": {
                "Cabinet / box sign (illuminated panel)": ["material_thickness", "cabinet_construction", "cabinet_depth"],
                "Light box (backlit panel)": ["material_thickness", "cabinet_construction", "cabinet_depth"]
            }
        },
        {
            "id": "dimensions",
            "text": "Overall sign dimensions (width \u00d7 height)?",
            "type": "text",
            "required": true,
            "hint": "Example: '8 ft \u00d7 2 ft', '48\" \u00d7 24\"'. For channel letters, this is the overall layout footprint.",
            "depends_on": null,
            "branches": null
        },
        {
            "id": "letter_height",
            "text": "Individual letter height (for channel/halo letters)?",
            "type": "text",
            "required": true,
            "hint": "Example: '12\"', '18\"', '24\"'. Larger letters = more material per letter.",
            "depends_on": null,
            "branches": null
        },
        {
            "id": "letter_count",
            "text": "How many letters / characters?",
            "type": "number",
            "required": false,
            "hint": "Include spaces between words. More characters = more fabrication time.",
            "depends_on": null,
            "branches": null
        },
        {
            "id": "material",
            "text": "Sign material?",
            "type": "choice",
            "options": [
                "Aluminum (standard for sign fabrication)",
                "Stainless steel (premium \u2014 brushed or mirror)",
                "Mild steel (industrial / rustic look)",
                "Combination (aluminum returns + stainless faces)"
            ],
            "required": true,
            "hint": "Aluminum is standard for channel letters (lightweight, corrosion resistant). Stainless for premium look.",
            "depends_on": null,
            "branches": null
        },
        {
            "id": "material_thickness",
            "text": "What material thickness / gauge?",
            "type": "choice",
            "options": [
                "0.063\" (thin — small signs only)",
                "0.080\" (standard for most cabinet signs)",
                "0.125\" (heavy duty — large or structural signs)",
                "0.190\" (extra heavy — oversized signs)"
            ],
            "required": false,
            "hint": "Thicker material is stronger and more rigid but heavier and more expensive. 0.080\" is standard for most cabinet signs under 10 ft.",
            "depends_on": "sign_type",
            "branches": null
        },
        {
            "id": "cabinet_construction",
            "text": "How should the cabinet be constructed?",
            "type": "choice",
            "options": [
                "Self-supporting box (sides welded — no internal frame)",
                "Corner bracing (angle or gusset at corners only)",
                "Full internal frame (tube frame with sheet skin)"
            ],
            "required": false,
            "hint": "Self-supporting works for most signs under 6 ft. Corner bracing adds rigidity for 6-10 ft signs. Full frame for 10+ ft or heavy signs.",
            "depends_on": "sign_type",
            "branches": null
        },
        {
            "id": "cabinet_depth",
            "text": "Cabinet depth (front to back)?",
            "type": "text",
            "required": false,
            "hint": "Common depths: 5\" (shallow / halo-lit), 8\" (standard), 12\" (deep / large letters). Deeper cabinets need more material.",
            "depends_on": "sign_type",
            "branches": null
        },
        {
            "id": "lighting_type",
            "text": "Lighting type?",
            "type": "choice",
            "options": [
                "Front-lit LED (standard \u2014 illuminated face)",
                "Halo / reverse-lit (glow behind letters)",
                "Front + halo combination",
                "Edge-lit",
                "Customer will supply LED modules"
            ],
            "required": false,
            "hint": "We fabricate the metal components. LED modules and power supplies are sourced separately.",
            "depends_on": null,
            "branches": null
        },
        {
            "id": "mounting_location",
            "text": "Where will this sign be mounted?",
            "type": "choice",
            "options": [
                "Building facade (raceway mount)",
                "Monument / ground sign structure",
                "Interior wall",
                "Freestanding / hanging"
            ],
            "required": false,
            "hint": "Raceway mount is most common for building signage. We fabricate the raceway (aluminum box that letters mount to).",
            "depends_on": null,
            "branches": null
        },
        {
            "id": "finish",
            "text": "Metal finish?",
            "type": "choice",
            "options": [
                "Powder coat (most common)",
                "Painted (custom colors)",
                "Clear coat / clearcoat (aluminum or stainless)",
                "Brushed stainless (no coating)",
                "Mirror polished stainless",
                "Patina / rust finish"
            ],
            "required": false,
            "hint": null,
            "depends_on": null,
            "branches": {
                "Clear coat / clearcoat (aluminum or stainless)": ["clear_coat_type"]
            }
        },
        {
            "id": "clear_coat_type",
            "text": "What type of clear coat?",
            "type": "choice",
            "options": [
                "2K urethane (professional — 3 coats)",
                "Spray can (basic — 2 coats)"
            ],
            "required": false,
            "hint": "2K urethane is a catalyzed professional-grade clear that requires a spray gun. More durable and UV resistant. Spray can is quick but less durable.",
            "depends_on": "finish",
            "branches": null
        }
    ]
}